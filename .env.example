# Local-only sample values. Copy to .env and replace every secret placeholder before starting apps/full profiles.
MYSQL_ROOT_PASSWORD=replace-me
MYSQL_PWD=replace-me
PII_HMAC_KEY=replace-with-at-least-32-random-bytes
MASK_SALT=replace-with-a-random-log-masking-key
MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-me
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
DEBEZIUM_DB_USER=root
DEBEZIUM_DB_PASSWORD=replace-me

# Optional host-port overrides. The local launcher maps the Redis and Kafka
# values to the Spring applications while keeping the dev profile's H2 database.
MYSQL_HOST_PORT=13307
REDIS_HOST_PORT=6379
KAFKA_HOST_PORT=9092
ELASTICSEARCH_HOST_PORT=9200
KIBANA_HOST_PORT=5601

# Unified identity is provided by auth-platform. The browser client is public and
# uses Authorization Code + PKCE, so it must not have a client secret.
CASDOOR_PUBLIC_URL=http://localhost:8000
CASDOOR_INTERNAL_URL=http://host.docker.internal:8000
CASDOOR_ORGANIZATION=risk-platform
CASDOOR_AUDIENCES=ragshared0client00000001-org-risk-platform
CASDOOR_EVALUATION_AUDIENCES=risk-bank-client
CASDOOR_RUNTIME_AUDIENCES=risk-runtime-client
CASDOOR_SERVICE_CLIENT_ID=risk-runtime-client
CASDOOR_SERVICE_CLIENT_SECRET=replace-after-running-auth-platform-provision

# Dedicated risk relationship-authorization data plane. The auth-platform server
# is started against this SpiceDB instance; do not reuse the shared identity DB.
AUTHZ_SERVER_URL=http://host.docker.internal:8212
AUTHZ_CLIENT_TOKEN=replace-with-risk-authz-server-token
RISK_SPICEDB_KEY=replace-with-risk-spicedb-preshared-key
RISK_AUTHZ_PG_PASSWORD=replace-with-risk-authz-postgres-password

# Baked into the risk-console image at build time.
VITE_AUTH_MODE=oidc
VITE_CASDOOR_ISSUER=http://localhost:8000
VITE_CASDOOR_CLIENT_ID=ragshared0client00000001-org-risk-platform
VITE_CASDOOR_ORGANIZATION=risk-platform
VITE_CASDOOR_SCOPE="openid profile offline_access"

NACOS_USERNAME=nacos
NACOS_PASSWORD=replace-me
NACOS_AUTH_TOKEN=replace-with-base64-secret-of-at-least-32-bytes
NACOS_AUTH_IDENTITY_KEY=risk-platform
NACOS_AUTH_IDENTITY_VALUE=replace-me

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me
