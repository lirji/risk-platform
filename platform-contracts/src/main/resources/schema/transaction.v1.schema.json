{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://risk-platform.local/schema/transaction.v1.schema.json",
  "title": "transaction.v1",
  "type": "object",
  "required": ["metadata", "channel", "bizType", "accountNo", "amountMinor", "currency", "eventTime"],
  "properties": {
    "metadata": { "$ref": "#/$defs/metadata" },
    "channel": { "type": "string", "minLength": 1 },
    "bizType": { "type": "string", "minLength": 1 },
    "accountNo": { "type": "string", "minLength": 1 },
    "counterpartyAccount": { "type": ["string", "null"] },
    "amountMinor": { "type": "integer", "minimum": 1 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "deviceId": { "type": ["string", "null"] },
    "ip": { "type": ["string", "null"] },
    "eventTime": { "type": "string", "format": "date-time" },
    "transactionStatus": { "enum": ["UNKNOWN", "FAILED", "SUCCESS"] }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["eventId", "correlationId", "sourceId", "txnId", "occurredAt", "schemaVersion"],
      "properties": {
        "eventId": { "type": "string", "minLength": 1 },
        "correlationId": { "type": "string", "minLength": 1 },
        "sourceId": { "type": "string", "minLength": 1 },
        "txnId": { "type": "string", "minLength": 1 },
        "occurredAt": { "type": "string", "format": "date-time" },
        "schemaVersion": { "const": 1 }
      }
    }
  }
}
